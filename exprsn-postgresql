    signature TEXT, -- Message signature
    verification_proof TEXT, -- Proof that can verify integrity without seeing content
    CONSTRAINT chk_not_self_message CHECK (sender_id <> recipient_id),
    CONSTRAINT chk_dm_content_not_empty CHECK (length(trim(content)) > 0)
);

