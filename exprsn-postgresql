    icon_url TEXT,
    is_featured BOOLEAN DEFAULT FALSE,
    post_count INTEGER DEFAULT 0,
    follower_count INTEGER DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    content_cid TEXT, -- Content ID for decentralized storage
    signature TEXT, -- Cryptographic signature
    federation_id TEXT, -- For federation across instances
    CONSTRAINT unq_topic_name UNIQUE (name),
    CONSTRAINT unq_topic_slug UNIQUE (slug)
);

CREATE INDEX IF NOT EXISTS idx_topics_parent_id ON public.topics(parent_id);
CREATE INDEX IF NOT EXISTS idx_topics_featured ON public.topics(is_featured);
CREATE INDEX IF NOT EXISTS idx_topics_follower_count ON public.topics(follower_count DESC);
CREATE INDEX IF NOT EXISTS idx_topics_content_cid ON public.topics(content_cid);

-- Media items table with content addressing
CREATE TABLE public.media_items (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    storage_provider_id INTEGER REFERENCES public.user_storage_credentials(id) ON DELETE SET NULL,
    media_type VARCHAR(50) NOT NULL, -- 'image', 'video', 'audio', 'document', etc.
    mime_type VARCHAR(100) NOT NULL,
    file_name VARCHAR(255) NOT NULL,
    file_size BIGINT NOT NULL, -- in bytes
    original_url TEXT NOT NULL,
    content_cid TEXT, -- Content identifier (IPFS/CID)
    content_hash TEXT, -- Cryptographic hash of content
    hash_algorithm VARCHAR(20) DEFAULT 'sha256', -- Algorithm used for content hash
    width INTEGER, -- for images/videos
    height INTEGER, -- for images/videos
    duration INTEGER, -- for videos/audio (seconds)
    thumbnail_url TEXT,
    thumbnail_cid TEXT, -- Content ID for thumbnail
    media_status VARCHAR(20) DEFAULT 'active', -- 'processing', 'active', 'error', 'removed'
    processing_error TEXT,
    alt_text TEXT, -- For accessibility
    caption TEXT,
    metadata JSONB, -- EXIF data, video codec info, etc.
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    custom_hash VARCHAR(64),
    encryption_method encryption_method DEFAULT NULL, -- If content is encrypted
    encryption_params JSONB, -- Encryption parameters if applicable
    signature TEXT, -- Digital signature of the creator
    replicated_on JSONB -- Where content is replicated in the network
);

CREATE INDEX IF NOT EXISTS idx_media_items_user_id ON public.media_items(user_id);
CREATE INDEX IF NOT EXISTS idx_media_items_media_type ON public.media_items(media_type);
CREATE INDEX IF NOT EXISTS idx_media_items_created_at ON public.media_items(created_at);
CREATE INDEX IF NOT EXISTS idx_media_items_custom_hash ON public.media_items(custom_hash);
CREATE INDEX IF NOT EXISTS idx_media_items_content_cid ON public.media_items(content_cid);
CREATE INDEX IF NOT EXISTS idx_media_items_content_hash ON public.media_items(content_hash);

-- Media albums
CREATE TABLE public.media_albums (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    cover_media_id INTEGER REFERENCES public.media_items(id) ON DELETE SET NULL,
    item_count INTEGER DEFAULT 0,
    visibility VARCHAR(20) DEFAULT 'public',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    content_cid TEXT, -- Content ID for decentralized storage
    signature TEXT -- Cryptographic signature
);

CREATE INDEX IF NOT EXISTS idx_media_albums_user_id ON public.media_albums(user_id);
CREATE INDEX IF NOT EXISTS idx_media_albums_content_cid ON public.media_albums(content_cid);

-- Media album items
CREATE TABLE public.media_album_items (
    id SERIAL PRIMARY KEY,
    album_id INTEGER NOT NULL REFERENCES public.media_albums(id) ON DELETE CASCADE,
    media_id INTEGER NOT NULL REFERENCES public.media_items(id) ON DELETE CASCADE,
    position INTEGER DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_album_media UNIQUE (album_id, media_id)
);

CREATE INDEX IF NOT EXISTS idx_media_album_items_album_id ON public.media_album_items(album_id);
CREATE INDEX IF NOT EXISTS idx_media_album_items_media_id ON public.media_album_items(media_id);

-- Media transformations (different sizes/formats)
CREATE TABLE public.media_transformations (
    id SERIAL PRIMARY KEY,
    media_id INTEGER NOT NULL REFERENCES public.media_items(id) ON DELETE CASCADE,
    transformation_type VARCHAR(50) NOT NULL, -- 'thumbnail', 'small', 'medium', 'large', 'compressed', etc.
    url TEXT NOT NULL,
    content_cid TEXT, -- Content ID for the transformed version
    width INTEGER,
    height INTEGER,
    file_size BIGINT,
    quality INTEGER, -- For compression level
    format VARCHAR(20), -- 'jpg', 'webp', 'mp4', etc.
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    content_hash TEXT, -- Hash of transformed content
    hash_algorithm VARCHAR(20) DEFAULT 'sha256'
);

CREATE INDEX IF NOT EXISTS idx_media_transformations_media_id ON public.media_transformations(media_id);
CREATE INDEX IF NOT EXISTS idx_media_transformations_type ON public.media_transformations(transformation_type);
CREATE INDEX IF NOT EXISTS idx_media_transformations_content_cid ON public.media_transformations(content_cid);

-- Enhanced Posts table with versioning and content addressing
CREATE TABLE IF NOT EXISTS public.posts (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    profile_id INTEGER REFERENCES public.user_profiles(id) ON DELETE SET NULL,
    content TEXT NOT NULL,
    attachment_urls JSONB,
    storage_provider_id INTEGER REFERENCES public.user_storage_credentials(id) ON DELETE SET NULL,
    visibility VARCHAR(20) DEFAULT 'public' NOT NULL,
    reply_to INTEGER REFERENCES public.posts(id) ON DELETE SET NULL,
    federation_id TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    metadata JSONB,
    group_id INTEGER,
    requires_token BOOLEAN DEFAULT FALSE,
    scheduled_for TIMESTAMP WITH TIME ZONE,
    expires_at TIMESTAMP WITH TIME ZONE,
    location JSONB,
    edit_history JSONB,
    custom_css TEXT,
    language VARCHAR(10),
    is_original BOOLEAN DEFAULT TRUE, -- Indicates if this is original content or a translation
    original_post_id INTEGER REFERENCES public.posts(id) ON DELETE SET NULL, -- For translations
    translation_language VARCHAR(10), -- For translations
    translation_type VARCHAR(20) DEFAULT 'machine', -- 'machine', 'human', 'community'
    current_version VARCHAR(20) DEFAULT '1.0.0', -- Current SEMVER version
    current_version_id INTEGER, -- Reference to current version in post_versions
    content_cid TEXT, -- Content identifier for decentralized storage
    content_hash TEXT, -- Cryptographic hash of content
    hash_algorithm VARCHAR(20) DEFAULT 'sha256',
    signature TEXT, -- Digital signature of the creator
    encryption_method encryption_method DEFAULT NULL, -- If content is encrypted
    encryption_params JSONB, -- Encryption parameters
    replicated_on JSONB, -- Where content is replicated
    merkle_root TEXT, -- For verifiable content trees
    zk_proof TEXT, -- For zero-knowledge proofs if applicable
    CONSTRAINT chk_posts_content_not_empty CHECK (length(trim(content)) > 0),
    CONSTRAINT chk_posts_visibility_values CHECK (visibility IN ('public', 'followers', 'private', 'group', 'unlisted'))
);

CREATE INDEX IF NOT EXISTS idx_posts_user_id ON public.posts(user_id);
CREATE INDEX IF NOT EXISTS idx_posts_profile_id ON public.posts(profile_id);
CREATE INDEX IF NOT EXISTS idx_posts_reply_to ON public.posts(reply_to);
CREATE INDEX IF NOT EXISTS idx_posts_group_id ON public.posts(group_id);
CREATE INDEX IF NOT EXISTS idx_posts_visibility ON public.posts(visibility);
CREATE INDEX IF NOT EXISTS idx_posts_federation_id ON public.posts(federation_id);
CREATE INDEX IF NOT EXISTS idx_posts_storage_provider_id ON public.posts(storage_provider_id);
CREATE INDEX IF NOT EXISTS idx_posts_created_at ON public.posts(created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_user_visibility_created ON public.posts(user_id, visibility, created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_scheduled_for ON public.posts(scheduled_for) WHERE scheduled_for IS NOT NULL;
CREATE INDEX IF NOT EXISTS idx_posts_expires_at ON public.posts(expires_at) WHERE expires_at IS NOT NULL;
CREATE INDEX IF NOT EXISTS idx_posts_requires_token ON public.posts(requires_token) WHERE requires_token = true;
CREATE INDEX IF NOT EXISTS idx_posts_content_gin ON public.posts USING gin(to_tsvector('english', content));
CREATE INDEX IF NOT EXISTS idx_posts_metadata ON public.posts USING gin(metadata);
CREATE INDEX IF NOT EXISTS idx_posts_original_post_id ON public.posts(original_post_id) WHERE original_post_id IS NOT NULL;
CREATE INDEX IF NOT EXISTS idx_posts_language ON public.posts(language);
CREATE INDEX IF NOT EXISTS idx_posts_current_version_id ON public.posts(current_version_id);
CREATE INDEX IF NOT EXISTS idx_posts_content_cid ON public.posts(content_cid);
CREATE INDEX IF NOT EXISTS idx_posts_content_hash ON public.posts(content_hash);

-- Post versions table for SEMVER style versioning
CREATE TABLE public.post_versions (
    id SERIAL PRIMARY KEY,
    post_id INTEGER NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
    version VARCHAR(20) NOT NULL, -- SEMVER format (major.minor.patch)
    content TEXT NOT NULL,
    attachment_urls JSONB,
    metadata JSONB,
    change_type version_change_type NOT NULL,
    change_description TEXT, -- Description of what changed
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    created_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    content_cid TEXT, -- Content ID for this specific version
    content_hash TEXT, -- Hash of this version's content
    hash_algorithm VARCHAR(20) DEFAULT 'sha256',
    signature TEXT, -- Digital signature for this version
    edited_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    edit_reason TEXT,
    previous_version VARCHAR(20), -- Link to previous version
    encryption_method encryption_method DEFAULT NULL,
    encryption_params JSONB,
    CONSTRAINT unq_post_version UNIQUE (post_id, version)
);

CREATE INDEX IF NOT EXISTS idx_post_versions_post_id ON public.post_versions(post_id);
CREATE INDEX IF NOT EXISTS idx_post_versions_version ON public.post_versions(version);
CREATE INDEX IF NOT EXISTS idx_post_versions_created_at ON public.post_versions(created_at);
CREATE INDEX IF NOT EXISTS idx_post_versions_content_cid ON public.post_versions(content_cid);
CREATE INDEX IF NOT EXISTS idx_post_versions_content_hash ON public.post_versions(content_hash);

