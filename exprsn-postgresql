);

CREATE INDEX IF NOT EXISTS idx_rate_limits_ip_endpoint ON public.rate_limits(ip_address, endpoint);
CREATE INDEX IF NOT EXISTS idx_rate_limits_user_endpoint ON public.rate_limits(user_id, endpoint);
CREATE INDEX IF NOT EXISTS idx_rate_limits_reset_at ON public.rate_limits(reset_at);

-- =============================================
-- DIGITAL ASSETS AND TOKEN-GATING (ENHANCED)
-- =============================================

-- User wallets
CREATE TABLE public.user_wallets (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    wallet_address TEXT NOT NULL,
    wallet_type VARCHAR(50) NOT NULL, -- 'ethereum', 'solana', etc.
    display_name VARCHAR(100),
    is_verified BOOLEAN DEFAULT FALSE,
    verification_date TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    signature TEXT, -- Cryptographic signature proving ownership
    verification_method VARCHAR(50), -- How the wallet was verified
    CONSTRAINT unq_user_wallet_address UNIQUE (user_id, wallet_address, wallet_type)
);

CREATE INDEX IF NOT EXISTS idx_user_wallets_user_id ON public.user_wallets(user_id);
CREATE INDEX IF NOT EXISTS idx_user_wallets_address ON public.user_wallets(wallet_address);

-- Digital assets
CREATE TABLE public.digital_assets (
    id SERIAL PRIMARY KEY,
    owner_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    asset_type VARCHAR(50) NOT NULL, -- 'nft', 'token', etc.
    contract_address TEXT,
    token_id TEXT,
    blockchain VARCHAR(50) NOT NULL,
    metadata JSONB NOT NULL,
    name VARCHAR(255),
    description TEXT,
    image_url TEXT,
    external_url TEXT,
    verified BOOLEAN DEFAULT FALSE,
    last_verified TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    content_cid TEXT, -- Content identifier for asset
    asset_signature TEXT, -- Creator signature
    version VARCHAR(20) DEFAULT '1.0.0' -- SEMVER version
);

CREATE INDEX IF NOT EXISTS idx_digital_assets_owner_id ON public.digital_assets(owner_id);
CREATE INDEX IF NOT EXISTS idx_digital_assets_contract ON public.digital_assets(contract_address, token_id);
CREATE INDEX IF NOT EXISTS idx_digital_assets_content_cid ON public.digital_assets(content_cid);
CREATE INDEX IF NOT EXISTS idx_digital_assets_version ON public.digital_assets(version);

-- Digital asset versions
CREATE TABLE public.digital_asset_versions (
    id SERIAL PRIMARY KEY,
    asset_id INTEGER NOT NULL REFERENCES public.digital_assets(id) ON DELETE CASCADE,
    version VARCHAR(20) NOT NULL, -- SEMVER format
    metadata JSONB NOT NULL,
    image_url TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    change_type version_change_type NOT NULL,
    change_description TEXT,
    created_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    content_cid TEXT, -- Content identifier for this version
    asset_signature TEXT, -- Signature for this version
    CONSTRAINT unq_asset_version UNIQUE (asset_id, version)
);

CREATE INDEX IF NOT EXISTS idx_digital_asset_versions_asset_id ON public.digital_asset_versions(asset_id);
CREATE INDEX IF NOT EXISTS idx_digital_asset_versions_version ON public.digital_asset_versions(version);
CREATE INDEX IF NOT EXISTS idx_digital_asset_versions_content_cid ON public.digital_asset_versions(content_cid);

-- Enhanced token-gated content
CREATE TABLE public.token_gated_content (
    id SERIAL PRIMARY KEY,
    post_id INTEGER NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
    asset_type VARCHAR(50) NOT NULL, -- 'nft', 'token', etc.
    asset_contract TEXT,
    asset_id TEXT, -- Optional, for specific token IDs
    min_balance NUMERIC(20,0), -- Minimum token balance required
    blockchain VARCHAR(50) NOT NULL,
    condition_type VARCHAR(50) NOT NULL, -- 'ownership', 'min_balance', 'whitelist', etc.
    condition_data JSONB, -- Additional condition parameters
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    version VARCHAR(20) DEFAULT '1.0.0', -- SEMVER version for the access policy
    verification_method VARCHAR(50) DEFAULT 'onchain', -- 'onchain', 'offchain_proof', 'merkle', etc.
    verification_params JSONB, -- Parameters for the verification method
    content_cid TEXT, -- Content identifier for this access policy
    policy_signature TEXT -- Signature of the policy
);

CREATE INDEX IF NOT EXISTS idx_token_gated_content_post_id ON public.token_gated_content(post_id);
CREATE INDEX IF NOT EXISTS idx_token_gated_content_asset ON public.token_gated_content(asset_contract, asset_id);
CREATE INDEX IF NOT EXISTS idx_token_gated_content_version ON public.token_gated_content(version);
CREATE INDEX IF NOT EXISTS idx_token_gated_content_content_cid ON public.token_gated_content(content_cid);

-- Token gating policy versions
CREATE TABLE public.token_gating_versions (
    id SERIAL PRIMARY KEY,
    gating_id INTEGER NOT NULL REFERENCES public.token_gated_content(id) ON DELETE CASCADE,
    version VARCHAR(20) NOT NULL, -- SEMVER format
    condition_data JSONB NOT NULL,
    verification_method VARCHAR(50) NOT NULL,
    verification_params JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    change_type version_change_type NOT NULL,
    change_description TEXT,
    created_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    content_cid TEXT, -- Content identifier for this version
    policy_signature TEXT, -- Signature for this version
    CONSTRAINT unq_gating_version UNIQUE (gating_id, version)
);

CREATE INDEX IF NOT EXISTS idx_token_gating_versions_gating_id ON public.token_gating_versions(gating_id);
CREATE INDEX IF NOT EXISTS idx_token_gating_versions_version ON public.token_gating_versions(version);
CREATE INDEX IF NOT EXISTS idx_token_gating_versions_content_cid ON public.token_gating_versions(content_cid);

-- Access token logs for token-gated content
CREATE TABLE public.token_access_logs (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    content_id INTEGER NOT NULL REFERENCES public.token_gated_content(id) ON DELETE CASCADE,
    wallet_id INTEGER REFERENCES public.user_wallets(id) ON DELETE SET NULL,
    verification_method VARCHAR(50) NOT NULL, -- 'wallet', 'token', 'whitelist', etc.
    successful BOOLEAN NOT NULL,
    verification_data JSONB,
    access_time TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    ip_address VARCHAR(45),
    content_version VARCHAR(20), -- Version of content accessed
    policy_version VARCHAR(20), -- Version of policy used
    access_proof TEXT, -- Cryptographic proof of access
