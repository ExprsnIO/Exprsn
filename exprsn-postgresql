CREATE INDEX IF NOT EXISTS idx_post_media_post_id ON public.post_media(post_id);
CREATE INDEX IF NOT EXISTS idx_post_media_media_id ON public.post_media(media_id);
CREATE INDEX IF NOT EXISTS idx_post_media_content_cid ON public.post_media(content_cid);

-- Post tagging
CREATE TABLE public.post_topics (
    id SERIAL PRIMARY KEY,
    post_id INTEGER NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
    topic_id INTEGER NOT NULL REFERENCES public.topics(id) ON DELETE CASCADE,
