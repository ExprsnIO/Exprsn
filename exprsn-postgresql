-- Token versioning trigger
CREATE OR REPLACE FUNCTION create_token_version()
RETURNS TRIGGER AS $$
DECLARE
  version_type version_change_type;
  new_version VARCHAR(20);
  major INT;
  minor INT;
  patch INT;
BEGIN
  -- Determine change type
  IF NEW.token_metadata IS NOT NULL AND NEW.token_metadata ? 'version_change_type' THEN
    version_type := NEW.token_metadata->>'version_change_type';
  ELSE
    version_type := 'minor'; -- Default to minor change
  END IF;

  -- Parse current version
  SELECT 
    COALESCE(split_part(OLD.version, '.', 1)::INT, 1) as maj,
    COALESCE(split_part(OLD.version, '.', 2)::INT, 0) as min,
    COALESCE(split_part(OLD.version, '.', 3)::INT, 0) as pat
  INTO major, minor, patch;

  -- Create new version number based on change type
  CASE version_type
    WHEN 'major' THEN
      new_version := (major + 1) || '.0.0';
    WHEN 'minor' THEN
      new_version := major || '.' || (minor + 1) || '.0';
    WHEN 'patch' THEN
      new_version := major || '.' || minor || '.' || (patch + 1);
    WHEN 'security' THEN
      new_version := major || '.' || minor || '.' || (patch + 1);
  END CASE;

  -- Insert into token_versions table
  INSERT INTO public.token_versions (
    token_id,
    version,
    change_type,
    change_description,
    created_by,
    permissions,
    token_hash,
    is_deprecated,
    successor_version
  ) VALUES (
    NEW.id,
    new_version,
    version_type,
    NEW.token_metadata->>'change_description',
    NEW.user_id,
    NEW.permissions_schema,
    NEW.token_hash,
    FALSE,
    OLD.version
  ) RETURNING id INTO NEW.current_version_id;

  -- Update token with new version info
  NEW.version := new_version;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

