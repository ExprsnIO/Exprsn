    media_ids INTEGER[], -- References to media_items
    read_at TIMESTAMP WITH TIME ZONE,
    encryption_method encryption_method DEFAULT 'aes256gcm', -- For end-to-end encrypted messages
    encryption_params JSONB, -- Algorithm-specific parameters
