CREATE INDEX IF NOT EXISTS idx_post_impressions_post_id ON public.post_impressions(post_id);
CREATE INDEX IF NOT EXISTS idx_post_impressions_user_id ON public.post_impressions(user_id);
CREATE INDEX IF NOT EXISTS idx_post_impressions_created_at ON public.post_impressions(created_at);
CREATE INDEX IF NOT EXISTS idx_post_impressions_post_version ON public.post_impressions(post_version);

-- Groups with decentralization support
CREATE TABLE IF NOT EXISTS public.groups (
