-- Updated password hashing check
CREATE OR REPLACE FUNCTION check_password_hash()
RETURNS TRIGGER AS $$
BEGIN
  -- Check if the password is properly hashed with the specified method
  CASE NEW.encryption_method
    WHEN 'bcrypt' THEN
      IF NEW.password !~ '^\$2[aby]\$\d+\$' THEN
        RAISE EXCEPTION 'Password must be hashed with bcrypt';
      END IF;
    WHEN 'argon2id' THEN
      IF NEW.password !~ '^\$argon2id\$' THEN
        RAISE EXCEPTION 'Password must be hashed with argon2id';
      END IF;
    WHEN 'scrypt' THEN
      IF NEW.password !~ '^\$scrypt\$' THEN
        RAISE EXCEPTION 'Password must be hashed with scrypt';
      END IF;
    WHEN 'pbkdf2' THEN
      IF NEW.password !~ '^\$pbkdf2-sha512\$' THEN
        RAISE EXCEPTION 'Password must be hashed with pbkdf2';
      END IF;
    ELSE
      RAISE EXCEPTION 'Unsupported password encryption method: %', NEW.encryption_method;
  END CASE;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER ensure_password_hashed
BEFORE INSERT OR UPDATE ON public.users
FOR EACH ROW
EXECUTE FUNCTION check_password_hash();

-- Post versioning trigger
CREATE OR REPLACE FUNCTION create_post_version()
RETURNS TRIGGER AS $$
DECLARE
  version_type version_change_type;
  new_version VARCHAR(20);
  major INT;
  minor INT;
  patch INT;
BEGIN
  -- Determine change type from metadata if available
  IF NEW.metadata IS NOT NULL AND NEW.metadata ? 'version_change_type' THEN
    version_type := NEW.metadata->>'version_change_type';
  ELSE
    version_type := 'minor'; -- Default to minor change
  END IF;

  -- Parse current version
  SELECT 
    COALESCE(split_part(OLD.current_version, '.', 1)::INT, 1) as maj,
    COALESCE(split_part(OLD.current_version, '.', 2)::INT, 0) as min,
    COALESCE(split_part(OLD.current_version, '.', 3)::INT, 0) as pat
  INTO major, minor, patch;

  -- Create new version number based on change type
  CASE version_type
    WHEN 'major' THEN
      new_version := (major + 1) || '.0.0';
    WHEN 'minor' THEN
      new_version := major || '.' || (minor + 1) || '.0';
    WHEN 'patch' THEN
      new_version := major || '.' || minor || '.' || (patch + 1);
    WHEN 'security' THEN
      new_version := major || '.' || minor || '.' || (patch + 1);
  END CASE;

  -- Insert into post_versions table
  INSERT INTO public.post_versions (
    post_id,
    version,
    content,
    attachment_urls,
    metadata,
    change_type,
    change_description,
    created_by,
    content_cid,
    content_hash,
    hash_algorithm,
    signature,
    previous_version,
    encryption_method,
    encryption_params
  ) VALUES (
    NEW.id,
    new_version,
    NEW.content,
    NEW.attachment_urls,
    NEW.metadata,
    version_type,
    NEW.metadata->>'change_description',
    NEW.user_id,
    NEW.content_cid,
    NEW.content_hash,
    NEW.hash_algorithm,
    NEW.signature,
    OLD.current_version,
    NEW.encryption_method,
    NEW.encryption_params
  ) RETURNING id INTO NEW.current_version_id;

  -- Update post with new version info
  NEW.current_version := new_version;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER post_version_update
BEFORE UPDATE OF content, attachment_urls, metadata ON public.posts
FOR EACH ROW
WHEN (OLD.* IS DISTINCT FROM NEW.*)
EXECUTE FUNCTION create_post_version();

