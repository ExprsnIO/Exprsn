CREATE INDEX IF NOT EXISTS idx_user_storage_credentials_user_id ON public.user_storage_credentials(user_id);

-- Storage headers
CREATE TABLE IF NOT EXISTS public.storage_headers (
    id SERIAL PRIMARY KEY,
    storage_id INTEGER NOT NULL REFERENCES public.user_storage_credentials(id) ON DELETE CASCADE,
