-- Update topic follower count
CREATE OR REPLACE FUNCTION update_topic_follower_count()
RETURNS TRIGGER AS $$
BEGIN
  IF TG_OP = 'INSERT' AND NEW.explicit_follow = TRUE THEN
    UPDATE public.topics SET follower_count = follower_count + 1 WHERE id = NEW.topic_id;
  ELSIF TG_OP = 'DELETE' AND OLD.explicit_follow = TRUE THEN
    UPDATE public.topics SET follower_count = follower_count - 1 WHERE id = OLD.topic_id;
  ELSIF TG_OP = 'UPDATE' AND NEW.explicit_follow != OLD.explicit_follow THEN
    IF NEW.explicit_follow = TRUE THEN
      UPDATE public.topics SET follower_count = follower_count + 1 WHERE id = NEW.topic_id;
    ELSE
      UPDATE public.topics SET follower_count = follower_count - 1 WHERE id = NEW.topic_id;
    END IF;
  END IF;
  
  RETURN NULL;
END;
$$ LANGUAGE plpgsql;

