-- =============================================
-- MODERATION AND REPORTING SYSTEM
-- =============================================

-- Content reports
CREATE TABLE public.content_reports (
    id SERIAL PRIMARY KEY,
    reporter_id INTEGER REFERENCES public.users(id) ON DELETE SET NULL, -- Allow anonymous reports
    reported_user_id INTEGER REFERENCES public.users(id) ON DELETE CASCADE,
    content_type VARCHAR(20) NOT NULL, -- 'post', 'comment', 'profile', etc.
    content_id INTEGER NOT NULL,
    reason VARCHAR(100) NOT NULL,
    details TEXT,
    evidence_urls JSONB, -- URLs to screenshots or other evidence
    status report_status DEFAULT 'open',
    assigned_to INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    resolution_note TEXT,
    action_taken moderation_action DEFAULT 'none',
    report_date TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    resolved_date TIMESTAMP WITH TIME ZONE,
    ip_address VARCHAR(45),
    automated_score INTEGER, -- Result of automated toxicity analysis
    is_appeal BOOLEAN DEFAULT FALSE,
    appeal_reason TEXT,
    parent_report_id INTEGER REFERENCES public.content_reports(id) ON DELETE SET NULL
);

CREATE INDEX IF NOT EXISTS idx_content_reports_reporter_id ON public.content_reports(reporter_id);
CREATE INDEX IF NOT EXISTS idx_content_reports_reported_user_id ON public.content_reports(reported_user_id);
CREATE INDEX IF NOT EXISTS idx_content_reports_content ON public.content_reports(content_type, content_id);
CREATE INDEX IF NOT EXISTS idx_content_reports_status ON public.content_reports(status);
CREATE INDEX IF NOT EXISTS idx_content_reports_date ON public.content_reports(report_date);

-- Content moderation actions
CREATE TABLE public.moderation_actions (
    id SERIAL PRIMARY KEY,
    user_id INTEGER REFERENCES public.users(id) ON DELETE CASCADE,
    moderator_id INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    action_type moderation_action NOT NULL,
    content_type VARCHAR(20), -- 'post', 'comment', 'profile', etc.
    content_id INTEGER, -- Optional, for content-specific actions
    reason TEXT NOT NULL,
    details JSONB,
    report_id INTEGER REFERENCES public.content_reports(id) ON DELETE SET NULL,
    action_date TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    expiry_date TIMESTAMP WITH TIME ZONE, -- For temporary restrictions
    is_active BOOLEAN DEFAULT TRUE,
    is_automated BOOLEAN DEFAULT FALSE,
    appeal_status VARCHAR(20), -- 'none', 'pending', 'approved', 'rejected'
    appeal_date TIMESTAMP WITH TIME ZONE,
    appeal_notes TEXT,
    overturned_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    overturned_date TIMESTAMP WITH TIME ZONE,
    overturned_reason TEXT
);

CREATE INDEX IF NOT EXISTS idx_moderation_actions_user_id ON public.moderation_actions(user_id);
CREATE INDEX IF NOT EXISTS idx_moderation_actions_moderator_id ON public.moderation_actions(moderator_id);
CREATE INDEX IF NOT EXISTS idx_moderation_actions_report_id ON public.moderation_actions(report_id);
CREATE INDEX IF NOT EXISTS idx_moderation_actions_content ON public.moderation_actions(content_type, content_id);
CREATE INDEX IF NOT EXISTS idx_moderation_actions_active ON public.moderation_actions(is_active);

-- Content classification (automated and manual)
CREATE TABLE public.content_classifications (
    id SERIAL PRIMARY KEY,
    content_type VARCHAR(20) NOT NULL, -- 'post', 'comment', 'profile', etc.
    content_id INTEGER NOT NULL,
    category VARCHAR(50) NOT NULL, -- 'adult', 'violence', 'hate_speech', etc.
    confidence NUMERIC(5,2), -- 0-100 for automated classifications
    is_automated BOOLEAN DEFAULT TRUE,
    classifier_version VARCHAR(50), -- For automated classifications
    moderator_id INTEGER REFERENCES public.users(id) ON DELETE SET NULL, -- For manual classifications
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_content_category UNIQUE (content_type, content_id, category)
);

CREATE INDEX IF NOT EXISTS idx_content_classifications_content ON public.content_classifications(content_type, content_id);
CREATE INDEX IF NOT EXISTS idx_content_classifications_category ON public.content_classifications(category);

-- Content warning labels
CREATE TABLE public.content_warnings (
    id SERIAL PRIMARY KEY,
    content_type VARCHAR(20) NOT NULL,
    content_id INTEGER NOT NULL,
    warning_type VARCHAR(50) NOT NULL, -- 'sensitive', 'adult', 'violence', etc.
    is_auto_generated BOOLEAN DEFAULT FALSE,
    added_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_content_warning UNIQUE (content_type, content_id, warning_type)
);

CREATE INDEX IF NOT EXISTS idx_content_warnings_content ON public.content_warnings(content_type, content_id);

-- Federation domain trust levels
CREATE TABLE public.domain_trust_levels (
    id SERIAL PRIMARY KEY,
    domain VARCHAR(255) NOT NULL,
    trust_level INTEGER NOT NULL DEFAULT 0, -- -10 to 10 scale, negative is untrusted
    is_blocked BOOLEAN DEFAULT FALSE,
    limit_federation BOOLEAN DEFAULT FALSE,
    notes TEXT,
    last_activity TIMESTAMP WITH TIME ZONE,
    incident_count INTEGER DEFAULT 0,
    added_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_domain UNIQUE (domain),
    CONSTRAINT chk_trust_range CHECK (trust_level BETWEEN -10 AND 10)
);

CREATE INDEX IF NOT EXISTS idx_domain_trust_levels_domain ON public.domain_trust_levels(domain);
CREATE INDEX IF NOT EXISTS idx_domain_trust_levels_blocked ON public.domain_trust_levels(is_blocked);

-- Moderation automation rules
CREATE TABLE public.moderation_rules (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    trigger_conditions JSONB NOT NULL, -- Conditions that trigger this rule
    actions JSONB NOT NULL, -- Actions to take when triggered
    is_active BOOLEAN DEFAULT TRUE,
    priority INTEGER DEFAULT 0,
    created_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_rule_name UNIQUE (name)
);

CREATE INDEX IF NOT EXISTS idx_moderation_rules_active ON public.moderation_rules(is_active);
CREATE INDEX IF NOT EXISTS idx_moderation_rules_priority ON public.moderation_rules(priority);

-- =============================================
-- MONETIZATION TABLES
-- =============================================

-- Content pricing tiers
CREATE TABLE public.content_tiers (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    price NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    benefits JSONB,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_positive_price CHECK (price >= 0)
);

CREATE INDEX IF NOT EXISTS idx_content_tiers_user_id ON public.content_tiers(user_id);

-- Connect posts to monetization tiers
CREATE TABLE public.post_monetization (
    id SERIAL PRIMARY KEY,
    post_id INTEGER NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
    tier_id INTEGER REFERENCES public.content_tiers(id) ON DELETE SET NULL,
    price NUMERIC(10,2), -- Individual price (if not using tier)
    currency VARCHAR(3) DEFAULT 'USD',
    is_premium BOOLEAN DEFAULT TRUE,
    preview_percentage INTEGER DEFAULT 10, -- How much of the content is free to preview (0-100)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_preview_range CHECK (preview_percentage BETWEEN 0 AND 100),
    CONSTRAINT chk_price_or_tier CHECK (
        (tier_id IS NULL AND price IS NOT NULL) OR
        (tier_id IS NOT NULL AND price IS NULL) OR
        (tier_id IS NOT NULL AND price IS NOT NULL) -- Can have both for price override
    )
);

CREATE INDEX IF NOT EXISTS idx_post_monetization_post_id ON public.post_monetization(post_id);
CREATE INDEX IF NOT EXISTS idx_post_monetization_tier_id ON public.post_monetization(tier_id);

-- User subscriptions to creators
CREATE TABLE public.creator_subscriptions (
    id SERIAL PRIMARY KEY,
    subscriber_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    creator_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    tier_id INTEGER REFERENCES public.content_tiers(id) ON DELETE SET NULL,
    status subscription_status DEFAULT 'active',
    price_at_time NUMERIC(10,2) NOT NULL, -- Historical price when subscribed
    currency VARCHAR(3) DEFAULT 'USD',
    schedule payment_schedule DEFAULT 'monthly',
    started_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    next_billing_date TIMESTAMP WITH TIME ZONE NOT NULL,
    cancelled_at TIMESTAMP WITH TIME ZONE,
    payment_method_id VARCHAR(255), -- External payment method reference
    auto_renew BOOLEAN DEFAULT TRUE,
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_not_self_subscribe CHECK (subscriber_id <> creator_id),
    CONSTRAINT unq_active_subscription UNIQUE (subscriber_id, creator_id, status) 
        WHERE status = 'active'
);

CREATE INDEX IF NOT EXISTS idx_creator_subs_subscriber ON public.creator_subscriptions(subscriber_id);
CREATE INDEX IF NOT EXISTS idx_creator_subs_creator ON public.creator_subscriptions(creator_id);
CREATE INDEX IF NOT EXISTS idx_creator_subs_next_billing ON public.creator_subscriptions(next_billing_date);
CREATE INDEX IF NOT EXISTS idx_creator_subs_status ON public.creator_subscriptions(status);

-- Individual content purchases (for non-subscription content)
CREATE TABLE public.content_purchases (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    post_id INTEGER NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
    amount NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    payment_method_id VARCHAR(255),
    transaction_id VARCHAR(255) UNIQUE,
    purchase_date TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    ip_address VARCHAR(45),
    status VARCHAR(20) DEFAULT 'completed',
    metadata JSONB,
    CONSTRAINT unq_user_post UNIQUE (user_id, post_id)
);

CREATE INDEX IF NOT EXISTS idx_content_purchases_user_id ON public.content_purchases(user_id);
CREATE INDEX IF NOT EXISTS idx_content_purchases_post_id ON public.content_purchases(post_id);

-- Track creator earnings and payouts
CREATE TABLE public.creator_earnings (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    amount NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    source_type VARCHAR(50) NOT NULL, -- 'subscription', 'purchase', 'tip', etc.
    source_id INTEGER NOT NULL, -- ID from the source table
    platform_fee NUMERIC(10,2) NOT NULL, -- Platform's cut
    net_amount NUMERIC(10,2) NOT NULL, -- After platform fee
    is_paid BOOLEAN DEFAULT FALSE,
    payout_id INTEGER,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_positive_amount CHECK (amount > 0),
    CONSTRAINT chk_positive_net CHECK (net_amount > 0)
);

CREATE INDEX IF NOT EXISTS idx_creator_earnings_user_id ON public.creator_earnings(user_id);
CREATE INDEX IF NOT EXISTS idx_creator_earnings_paid ON public.creator_earnings(is_paid);
CREATE INDEX IF NOT EXISTS idx_creator_earnings_created ON public.creator_earnings(created_at);

-- Creator payout records
CREATE TABLE public.creator_payouts (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    amount NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    payment_method VARCHAR(50) NOT NULL, -- 'bank_transfer', 'paypal', etc.
    payment_details JSONB, -- Account information (encrypted or tokenized)
    status payout_status DEFAULT 'pending',
    reference_code VARCHAR(100),
    requested_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    processed_at TIMESTAMP WITH TIME ZONE,
    metadata JSONB,
    CONSTRAINT chk_positive_payout CHECK (amount > 0)
);

CREATE INDEX IF NOT EXISTS idx_creator_payouts_user_id ON public.creator_payouts(user_id);
CREATE INDEX IF NOT EXISTS idx_creator_payouts_status ON public.creator_payouts(status);
CREATE INDEX IF NOT EXISTS idx_creator_payouts_requested ON public.creator_payouts(requested_at);

-- Tips and donations
CREATE TABLE public.user_tips (
    id SERIAL PRIMARY KEY,
    from_user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    to_user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    post_id INTEGER REFERENCES public.posts(id) ON DELETE SET NULL,
    amount NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    message TEXT,
    is_anonymous BOOLEAN DEFAULT FALSE,
    transaction_id VARCHAR(255) UNIQUE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_not_self_tip CHECK (from_user_id <> to_user_id),
    CONSTRAINT chk_positive_tip CHECK (amount > 0)
);

CREATE INDEX IF NOT EXISTS idx_user_tips_from_user ON public.user_tips(from_user_id);
CREATE INDEX IF NOT EXISTS idx_user_tips_to_user ON public.user_tips(to_user_id);
CREATE INDEX IF NOT EXISTS idx_user_tips_post_id ON public.user_tips(post_id);

-- Payment methods
CREATE TABLE public.user_payment_methods (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    payment_type VARCHAR(50) NOT NULL, -- 'credit_card', 'paypal', etc.
    is_default BOOLEAN DEFAULT FALSE,
    provider_token TEXT NOT NULL, -- Tokenized payment method from payment provider
    last_four VARCHAR(4),
    expiry_date VARCHAR(7), -- 'MM/YYYY'
    cardholder_name VARCHAR(255),
    billing_address JSONB,
    is_verified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    metadata JSONB
);

CREATE INDEX IF NOT EXISTS idx_user_payment_methods_user_id ON public.user_payment_methods(user_id);

-- Subscription plans
CREATE TABLE IF NOT EXISTS public.subscription_plans (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    price NUMERIC(10,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD' NOT NULL,
    billing_interval VARCHAR(20) DEFAULT 'monthly' NOT NULL,
    features JSONB,
    is_active BOOLEAN DEFAULT TRUE,
    max_profiles INTEGER DEFAULT 1,
    max_storage_gb INTEGER DEFAULT 5,
