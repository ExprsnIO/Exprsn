CREATE INDEX IF NOT EXISTS idx_group_permissions_group_id ON public.group_permissions(group_id);

-- Group memberships
CREATE TABLE IF NOT EXISTS public.user_group_memberships (
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    group_id INTEGER NOT NULL REFERENCES public.groups(id) ON DELETE CASCADE,
    role VARCHAR(50) DEFAULT 'member' NOT NULL,
    joined_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    invited_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    status VARCHAR(20) DEFAULT 'active' NOT NULL,
