-- Update analytics counters on post actions
CREATE OR REPLACE FUNCTION update_post_analytics()
RETURNS TRIGGER AS $$
BEGIN
  -- Create analytics record if it doesn't exist
  INSERT INTO public.post_analytics (post_id, updated_at)
  VALUES (NEW.post_id, CURRENT_TIMESTAMP)
  ON CONFLICT (post_id) DO NOTHING;
  
  -- Update the appropriate counter
  IF TG_TABLE_NAME = 'likes' AND TG_OP = 'INSERT' THEN
    UPDATE public.post_analytics SET likes = likes + 1 WHERE post_id = NEW.post_id;
  ELSIF TG_TABLE_NAME = 'likes' AND TG_OP = 'DELETE' THEN
    UPDATE public.post_analytics SET likes = likes - 1 WHERE post_id = OLD.post_id;
  ELSIF TG_TABLE_NAME = 'reposts' AND TG_OP = 'INSERT' THEN
    UPDATE public.post_analytics SET reposts = reposts + 1 WHERE post_id = NEW.post_id;
  ELSIF TG_TABLE_NAME = 'reposts' AND TG_OP = 'DELETE' THEN
    UPDATE public.post_analytics SET reposts = reposts - 1 WHERE post_id = OLD.post_id;
  END IF;
  
  RETURN NULL;
END;
$$ LANGUAGE plpgsql;

