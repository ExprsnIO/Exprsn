-- =============================================
-- EXPRSN PLATFORM - ENHANCED SCHEMA FOR DECENTRALIZATION
-- =============================================

-- Enable necessary extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pgcrypto";
CREATE EXTENSION IF NOT EXISTS "hstore";
CREATE EXTENSION IF NOT EXISTS "pg_trgm";

-- =============================================
-- ENHANCED CORE TYPES
-- =============================================

-- Create custom types for the system
CREATE TYPE subscription_status AS ENUM ('active', 'expired', 'cancelled', 'pending');
CREATE TYPE profile_type AS ENUM ('personal', 'professional', 'business', 'creative');
CREATE TYPE certificate_status AS ENUM ('active', 'revoked', 'expired');
CREATE TYPE token_validity_type AS ENUM ('permanent', 'expiry_date', 'duration_days', 'max_uses');
CREATE TYPE token_visibility AS ENUM ('public', 'private', 'restricted');
CREATE TYPE storage_provider AS ENUM ('s3', 'gcs', 'azure', 'cloudflare', 'backblaze', 'ipfs', 'arweave', 'custom');
CREATE TYPE payment_schedule AS ENUM ('one_time', 'monthly', 'yearly', 'weekly');
CREATE TYPE payout_status AS ENUM ('pending', 'processing', 'completed', 'failed');
CREATE TYPE report_status AS ENUM ('open', 'under_review', 'resolved', 'rejected');
CREATE TYPE moderation_action AS ENUM ('none', 'warn', 'hide_content', 'restrict_account', 'suspend_account', 'ban_account');

-- New encryption methods enum for enhanced security options
CREATE TYPE encryption_method AS ENUM (
    'bcrypt', 
    'argon2id', 
    'scrypt', 
    'pbkdf2', 
    'aes256gcm', 
    'chacha20poly1305', 
    'rsa', 
    'ed25519', 
    'ecies'
);

-- Create enum for version change types
CREATE TYPE version_change_type AS ENUM (
    'major',  -- Breaking changes
    'minor',  -- New features, backward compatible
    'patch',  -- Bug fixes, backward compatible
    'security' -- Security patches
);

-- =============================================
-- CORE USER TABLES (ENHANCED)
-- =============================================

-- Users table - core user data with enhanced encryption
CREATE TABLE IF NOT EXISTS public.users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(30) NOT NULL,
    email VARCHAR(255) NOT NULL,
    password TEXT NOT NULL,
    encryption_method encryption_method DEFAULT 'bcrypt' NOT NULL,
    encryption_params JSONB DEFAULT '{"cost": 12}', -- Algorithm-specific parameters
    role VARCHAR(20) DEFAULT 'user' NOT NULL,
    display_name VARCHAR(100) NOT NULL,
    bio TEXT,
    avatar_url TEXT,
    subdomain VARCHAR(63),
    federation_id TEXT,
    did TEXT, -- Decentralized Identifier
    public_key TEXT, -- For verification and encryption
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    last_login TIMESTAMP WITH TIME ZONE,
    verified BOOLEAN DEFAULT FALSE,
    is_active BOOLEAN DEFAULT TRUE,
    settings JSONB NOT NULL DEFAULT '{}',
    current_theme_id INTEGER,
    default_profile_id INTEGER,
    totp_secret TEXT,
    backup_codes JSONB,
    account_type VARCHAR(20) DEFAULT 'standard',
    meta_data JSONB,
    content_pub_key TEXT, -- Public key for content signing
    content_signature_algo VARCHAR(50) DEFAULT 'ed25519', -- Default signature algorithm
    CONSTRAINT chk_users_email_format CHECK (email ~* '^[A-Za-z0-9._%-]+@[A-Za-z0-9.-]+[.][A-Za-z]+$'),
    CONSTRAINT chk_users_username_format CHECK (username ~* '^[a-zA-Z0-9_]{3,30}$'),
    CONSTRAINT chk_users_subdomain_format CHECK (subdomain IS NULL OR subdomain ~* '^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$'),
    CONSTRAINT chk_users_password_min_length CHECK (length(password) >= 8)
);

-- Add user indexes
CREATE INDEX IF NOT EXISTS idx_users_username ON public.users(username);
CREATE INDEX IF NOT EXISTS idx_users_email ON public.users(email);
CREATE INDEX IF NOT EXISTS idx_users_subdomain ON public.users(subdomain);
CREATE INDEX IF NOT EXISTS idx_users_federation_id ON public.users(federation_id);
CREATE INDEX IF NOT EXISTS idx_users_current_theme_id ON public.users(current_theme_id);
CREATE INDEX IF NOT EXISTS idx_users_default_profile_id ON public.users(default_profile_id);
CREATE INDEX IF NOT EXISTS idx_users_did ON public.users(did);

-- User profiles - support for multiple profiles per user
CREATE TABLE IF NOT EXISTS public.user_profiles (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    name VARCHAR(100) NOT NULL,
    profile_type profile_type DEFAULT 'personal' NOT NULL,
    is_default BOOLEAN DEFAULT FALSE,
    bio TEXT,
    avatar_url TEXT,
    banner_url TEXT,
    theme_id INTEGER,
    settings JSONB,
    visibility VARCHAR(20) DEFAULT 'public',
    meta_data JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    custom_domain VARCHAR(255),
    custom_css TEXT,
    is_active BOOLEAN DEFAULT TRUE,
    profile_signature TEXT, -- Cryptographic signature of profile data
    content_cid TEXT -- Content identifier (IPFS/CID) for decentralized storage
);

CREATE INDEX IF NOT EXISTS idx_user_profiles_user_id ON public.user_profiles(user_id);
CREATE INDEX IF NOT EXISTS idx_user_profiles_theme_id ON public.user_profiles(theme_id);
CREATE INDEX IF NOT EXISTS idx_user_profiles_is_default ON public.user_profiles(is_default);
CREATE INDEX IF NOT EXISTS idx_user_profiles_content_cid ON public.user_profiles(content_cid);

-- Subdomain registrations
CREATE TABLE IF NOT EXISTS public.subdomain_registrations (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    subdomain VARCHAR(63) NOT NULL,
    status VARCHAR(20) DEFAULT 'pending' NOT NULL,
    verification_token TEXT,
    verified_at TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    settings JSONB,
    CONSTRAINT chk_subdomain_format CHECK (subdomain ~* '^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$')
);

CREATE INDEX IF NOT EXISTS idx_subdomain_registrations_user_id ON public.subdomain_registrations(user_id);
CREATE INDEX IF NOT EXISTS idx_subdomain_registrations_subdomain ON public.subdomain_registrations(subdomain);
CREATE INDEX IF NOT EXISTS idx_subdomain_registrations_status ON public.subdomain_registrations(status);

-- Enhanced API tokens with versioning support
CREATE TABLE IF NOT EXISTS public.api_tokens (
    id SERIAL PRIMARY KEY,
    token TEXT NOT NULL,
    user_id INTEGER NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
    name VARCHAR(100) NOT NULL,
    scope TEXT NOT NULL,
    last_used_at TIMESTAMP WITH TIME ZONE,
    expires_at TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE,
    ip_whitelist TEXT[],
    version VARCHAR(20) DEFAULT '1.0.0', -- SEMVER format
    current_version_id INTEGER, -- Latest version reference
    encryption_method encryption_method DEFAULT 'bcrypt',
    encryption_params JSONB,
    token_hash TEXT, -- For verification without exposing the token
    rotation_period INTERVAL, -- For automatic token rotation
    last_rotated_at TIMESTAMP WITH TIME ZONE,
    permissions_schema JSONB, -- Detailed permissions structure
    token_metadata JSONB -- Additional token information
);

CREATE INDEX IF NOT EXISTS idx_api_tokens_user_id ON public.api_tokens(user_id);
CREATE INDEX IF NOT EXISTS idx_api_tokens_token_hash ON public.api_tokens(token_hash);
CREATE INDEX IF NOT EXISTS idx_api_tokens_current_version_id ON public.api_tokens(current_version_id);

-- Token version history (for SEMVER versioning)
CREATE TABLE IF NOT EXISTS public.token_versions (
    id SERIAL PRIMARY KEY,
    token_id INTEGER NOT NULL REFERENCES public.api_tokens(id) ON DELETE CASCADE,
    version VARCHAR(20) NOT NULL, -- SEMVER format (major.minor.patch)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    change_type version_change_type NOT NULL,
    change_description TEXT,
    created_by INTEGER REFERENCES public.users(id) ON DELETE SET NULL,
    permissions JSONB, -- Snapshot of permissions at this version
    token_hash TEXT, -- Hash of the token at this version
    is_deprecated BOOLEAN DEFAULT FALSE,
    deprecation_reason TEXT,
    successor_version VARCHAR(20),
    metadata JSONB,
    CONSTRAINT unq_token_version UNIQUE (token_id, version)
);

CREATE INDEX IF NOT EXISTS idx_token_versions_token_id ON public.token_versions(token_id);
CREATE INDEX IF NOT EXISTS idx_token_versions_version ON public.token_versions(version);

-- =============================================
-- CONTENT TABLES (ENHANCED FOR DECENTRALIZATION)
-- =============================================

-- Topics/tags system
CREATE TABLE public.topics (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
