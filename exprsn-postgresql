    conversation_cid TEXT, -- Content identifier for the conversation
    CONSTRAINT chk_different_users CHECK (user1_id < user2_id), -- Ensures unique conversation pairs
    CONSTRAINT unq_conversation UNIQUE (user1_id, user2_id)
);

CREATE INDEX IF NOT EXISTS idx_dm_conversations_user1_id ON public.dm_conversations(user1_id);
